{
  "description": "Agentic plugin hooks — convention and commit message checks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'EnterPlanMode is disabled. Agents manage planning through conversation, not native plan mode. If you are the developer agent, write code immediately — do not plan.' >&2 && exit 2",
            "timeout": 5,
            "statusMessage": "Blocking native plan mode..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/block-secrets.sh",
            "timeout": 5,
            "statusMessage": "Checking for secrets..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-commit-msg.sh",
            "timeout": 5,
            "statusMessage": "Validating commit message..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-conventions.sh",
            "timeout": 10,
            "statusMessage": "Checking conventions..."
          }
        ]
      }
    ]
  }
}
